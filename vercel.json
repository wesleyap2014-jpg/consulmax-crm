{
  "framework": "vite",
  "buildCommand": "npm install && node scripts/patch-maggi-lead-select.mjs && npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/robots/sync-groups.ts": {
      "maxDuration": 800
    },
    "api/cron/sync-bb-complete.ts": {
      "maxDuration": 800
    },
    "api/agenda/birthday-whatsapp.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/sync-bb-complete",
      "schedule": "0 */4 * * *"
    },
    {
      "path": "/api/agenda/birthday-whatsapp",
      "schedule": "30 8 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/.*)(?!.*\\.).*)",
      "destination": "/index.html"
    }
  ]
}
