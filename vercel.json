{
  "framework": "vite",
  "buildCommand": "npm install && npm run build",
  "outputDirectory": "dist",
  "crons": [
    {
      "path": "/api/whatsapp/send",
      "schedule": "*/5 * * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/.*)(?!.*\\.).*)",
      "destination": "/index.html"
    }
  ]
}
